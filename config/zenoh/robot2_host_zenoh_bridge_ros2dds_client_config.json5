{
  plugins: {
    ros2dds: {
      allow: {
        publishers: [
          ".*/robot2/amcl_pose",
          ".*/robot2/tf",
          ".*/robot2/battery_state"
        ],
        subscribers: [],
        service_servers: [],
        service_clients: [],
        action_servers: [".*/robot2/navigate_to_pose"],
