      pub_max_frequencies: [
        ".*/robot2/battery_state=1",
        ".*/robot2/amcl_pose=5"
      ],
    },
  },
  mode: "client",
  connect: {
    endpoints: ["tcp/192.168.11.104:7447"]
  },
  listen: {
    endpoints: []
  },
}
